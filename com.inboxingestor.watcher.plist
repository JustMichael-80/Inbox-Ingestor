<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.inboxingestor.watcher</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>REPLACE_WITH_FULL_PATH_TO/pdf_inbox_watcher.py</string>
        <string>REPLACE_WITH_FULL_PATH_TO/your_inbox_folder</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/pdf_inbox_watcher.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/pdf_inbox_watcher_error.log</string>
</dict>
</plist>
